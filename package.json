{
  "name": "agent-shell",
  "version": "0.1.0",
  "type": "module",
  "description": "AI-first CLI framework - 2 tools + vector discovery",
  "license": "MIT",
  "author": "Mauricio Perera",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MauricioPerera/Agent-Shell.git"
  },
  "homepage": "https://github.com/MauricioPerera/Agent-Shell#readme",
  "bugs": {
    "url": "https://github.com/MauricioPerera/Agent-Shell/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "cli",
    "llm",
    "mcp",
    "shell",
    "vector-search",
    "command-registry",
    "rbac",
    "typescript"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agent-shell": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./mcp": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "bun-types": "^1.3.6",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
